---
interface Props {
  variant?: "primary" | "secondary";
  size?: "lg" | "sm";
  href?: string;
  type?: "button" | "submit";
  class?: string;
}

const { variant = "primary", size = "lg", href, type = "button", class: className = "" } = Astro.props;

const base = "inline-flex items-center justify-center gap-xs rounded-xl font-medium transition-all duration-150";

const variantClasses =
  variant === "primary"
    ? "btn-gradient text-white"
    : "bg-canvas text-ink border border-hairline shadow-level-1 hover:bg-canvas-soft hover:border-hairline-strong";

const sizeClasses = size === "lg" ? "text-button-lg px-xl py-sm" : "text-button-md px-lg py-xs";

const classes = [base, variantClasses, sizeClasses, className].join(" ");

const Tag = href ? "a" : "button";
---

<Tag class={classes} href={href} type={href ? undefined : type}>
  <slot />
</Tag>
