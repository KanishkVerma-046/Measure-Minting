---
import MeshGradient from "./MeshGradient.astro";

interface Props {
  compact?: boolean;
  class?: string;
}

const { compact = false, class: className = "" } = Astro.props;
---

<section
  class={[
    "relative overflow-hidden",
    compact
      ? "px-md py-2xl sm:py-3xl sm:px-lg lg:py-5xl"
      : "px-md py-4xl sm:py-5xl sm:px-lg lg:py-section",
    className,
  ].join(" ")}
  style="background: linear-gradient(160deg, var(--color-canvas) 0%, var(--color-link-bg-soft) 60%, var(--color-canvas-soft-2) 100%);"
>
  <MeshGradient />
  <div class="relative mx-auto max-w-[1400px] text-center">
    <slot name="badge" />
    <h1 class={compact ? "mt-md text-display-lg text-ink text-balance" : "mt-lg text-display-xl text-ink text-balance"}>
      <slot name="title" />
    </h1>
    <p class="mx-auto mt-sm max-w-[60ch] text-body-lg text-body text-pretty">
      <slot name="subtitle" />
    </p>
    <div class="mt-lg flex flex-wrap items-center justify-center gap-sm">
      <slot name="actions" />
    </div>
    <div class="mt-2xl">
      <slot />
    </div>
  </div>
</section>
