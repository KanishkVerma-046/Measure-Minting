---
import { CATEGORIES } from "../lib/units";

const CALC_CATEGORIES = [
  { label: "Financial", href: "/calculators/#financial" },
  { label: "Health & Fitness", href: "/calculators/#health" },
  { label: "Math", href: "/calculators/#math" },
  { label: "Other", href: "/calculators/#other" },
];
---

<header class="sticky top-0 z-50 border-b border-hairline bg-canvas/95 backdrop-blur-sm">
  <div class="mx-auto flex h-16 max-w-[1400px] items-center justify-between gap-md px-md sm:px-lg">
    <a href="/" class="shrink-0 text-display-sm text-ink tracking-tight">
      Measure<span class="text-link">Minting</span>
    </a>

    <nav aria-label="Main" class="hidden items-center gap-xxs lg:flex">
      {
        CATEGORIES.map((category) => (
          <a
            href={`/${category.id}/`}
            class="rounded-lg px-sm py-xs text-body-sm text-body transition-colors hover:bg-link-bg-soft hover:text-link"
          >
            {category.label}
          </a>
        ))
      }

      <!-- Calculators dropdown -->
      <details class="relative">
        <summary
          class="list-none cursor-pointer rounded-lg px-sm py-xs text-body-sm text-body transition-colors hover:bg-link-bg-soft hover:text-link flex items-center gap-xxs [&::-webkit-details-marker]:hidden"
        >
          Calculators
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="absolute left-0 top-full mt-1 w-52 rounded-xl border border-hairline bg-canvas p-xs shadow-level-5">
          {CALC_CATEGORIES.map((cat) => (
            <a href={cat.href} class="block rounded-lg px-sm py-xs text-body-sm text-body hover:bg-link-bg-soft hover:text-link">
              {cat.label}
            </a>
          ))}
          <div class="my-xs border-t border-hairline"></div>
          <a href="/calculators/" class="block rounded-lg px-sm py-xs text-body-sm-strong text-link hover:bg-link-bg-soft">
            All Calculators →
          </a>
        </div>
      </details>
    </nav>

    <div class="hidden items-center gap-xxs lg:flex ml-md border-l border-hairline pl-md">
      <a href="/about/" class="rounded-lg px-sm py-xs text-body-sm text-body transition-colors hover:bg-link-bg-soft hover:text-link">About</a>
      <a href="/contact/" class="rounded-lg px-sm py-xs text-body-sm text-body transition-colors hover:bg-link-bg-soft hover:text-link">Contact</a>
    </div>

    <div class="flex shrink-0 items-center gap-xs">
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="flex h-9 w-9 items-center justify-center rounded-lg border border-hairline bg-canvas text-ink transition-colors hover:bg-link-bg-soft hover:text-link hover:border-link"
      >
        <svg id="theme-icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/>
        </svg>
        <svg id="theme-icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
      </button>

      <a
        href="/calculator/"
        class="hidden lg:inline-flex h-8 items-center rounded-lg border border-hairline bg-canvas px-sm text-body-sm-strong text-ink transition-colors hover:bg-link-bg-soft hover:text-link hover:border-link"
      >
        Sci Calc
      </a>
      <a
        href="/all-converters/"
        class="hidden lg:inline-flex h-8 items-center rounded-lg border border-hairline bg-canvas px-sm text-body-sm-strong text-ink transition-colors hover:bg-link-bg-soft hover:text-link hover:border-link"
      >
        Browse all
      </a>
    </div>

    <details class="relative lg:hidden">
      <summary
        aria-label="Open menu"
        class="flex h-9 w-9 list-none items-center justify-center rounded-lg border border-hairline [&::-webkit-details-marker]:hidden"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
      </summary>
      <nav
        aria-label="Mobile menu"
        class="absolute right-0 top-12 flex w-60 flex-col gap-xxs rounded-xl border border-hairline bg-canvas p-sm shadow-level-5"
      >
        <p class="px-sm py-xxs text-caption text-mute font-medium uppercase tracking-wider">Converters</p>
        {
          CATEGORIES.map((category) => (
            <a href={`/${category.id}/`} class="rounded-lg px-sm py-xs text-body-sm text-body hover:bg-link-bg-soft hover:text-link">
              {category.label}
            </a>
          ))
        }
        <div class="my-xs border-t border-hairline"></div>
        <p class="px-sm py-xxs text-caption text-mute font-medium uppercase tracking-wider">Calculators</p>
        {CALC_CATEGORIES.map((cat) => (
          <a href={cat.href} class="rounded-lg px-sm py-xs text-body-sm text-body hover:bg-link-bg-soft hover:text-link">
            {cat.label}
          </a>
        ))}
        <div class="my-xs border-t border-hairline"></div>
        <a href="/calculator/" class="rounded-lg px-sm py-xs text-body-sm-strong text-ink hover:bg-canvas-soft">
          Scientific Calculator
        </a>
        <a href="/all-converters/" class="rounded-lg px-sm py-xs text-body-sm-strong text-ink hover:bg-canvas-soft">
          Browse all converters
        </a>
        <div class="my-xs border-t border-hairline"></div>
        <p class="px-sm py-xxs text-caption text-mute font-medium uppercase tracking-wider">Company</p>
        <a href="/about/" class="rounded-lg px-sm py-xs text-body-sm text-body hover:bg-link-bg-soft hover:text-link">About</a>
        <a href="/contact/" class="rounded-lg px-sm py-xs text-body-sm text-body hover:bg-link-bg-soft hover:text-link">Contact</a>
        <a href="/privacy/" class="rounded-lg px-sm py-xs text-body-sm text-body hover:bg-link-bg-soft hover:text-link">Privacy Policy</a>
        <a href="/terms/" class="rounded-lg px-sm py-xs text-body-sm text-body hover:bg-link-bg-soft hover:text-link">Terms & Conditions</a>
      </nav>
    </details>
  </div>
</header>

<script>
  const toggleBtn = document.getElementById("theme-toggle");
  const moonIcon = document.getElementById("theme-icon-moon");
  const sunIcon = document.getElementById("theme-icon-sun");

  function applyIcons(isDark: boolean) {
    if (isDark) {
      moonIcon?.classList.add("hidden");
      sunIcon?.classList.remove("hidden");
    } else {
      moonIcon?.classList.remove("hidden");
      sunIcon?.classList.add("hidden");
    }
  }

  applyIcons(document.documentElement.classList.contains("dark"));

  toggleBtn?.addEventListener("click", () => {
    const nowDark = !document.documentElement.classList.contains("dark");
    document.documentElement.classList.toggle("dark", nowDark);
    localStorage.setItem("mm-theme", nowDark ? "dark" : "light");
    applyIcons(nowDark);
  });

  // Close details dropdowns when clicking outside
  document.addEventListener("click", (e) => {
    document.querySelectorAll("details[open]").forEach((d) => {
      if (!d.contains(e.target as Node)) (d as HTMLDetailsElement).open = false;
    });
  });
</script>
