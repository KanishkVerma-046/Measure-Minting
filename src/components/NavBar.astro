---
// DESIGN.md `nav-bar` / `nav-link`. No auth CTAs (signup/login) — this product
// has no accounts — the nav-cta-ask-ai bordered-button token is repurposed as
// a single "Browse all" discovery action instead.
import { CATEGORIES } from "../lib/units";
---

<header class="sticky top-0 z-50 border-b border-hairline bg-canvas">
  <div class="mx-auto flex h-16 max-w-[1400px] items-center justify-between gap-md px-md sm:px-lg">
    <a href="/" class="shrink-0 text-display-sm text-ink">
      Measure<span class="text-link">Minting</span>
    </a>

    <nav aria-label="Categories" class="hidden items-center gap-xxs md:flex">
      {
        CATEGORIES.map((category) => (
          <a
            href={`/${category.id}/`}
            class="rounded-full px-sm py-xs text-body-sm text-body transition-colors hover:bg-canvas-soft hover:text-ink"
          >
            {category.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden shrink-0 md:block">
      <a
        href="/all-converters/"
        class="inline-flex h-7 items-center rounded-sm border border-hairline bg-canvas px-xs text-body-sm-strong text-ink transition-colors hover:bg-canvas-soft"
      >
        Browse all
      </a>
    </div>

    <details class="relative md:hidden">
      <summary
        aria-label="Open menu"
        class="flex h-9 w-9 list-none items-center justify-center rounded-sm border border-hairline [&::-webkit-details-marker]:hidden"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
      </summary>
      <nav
        aria-label="Categories"
        class="absolute right-0 top-12 flex w-56 flex-col gap-xxs rounded-md border border-hairline bg-canvas p-sm shadow-level-5"
      >
        {
          CATEGORIES.map((category) => (
            <a href={`/${category.id}/`} class="rounded-sm px-sm py-xs text-body-sm text-body hover:bg-canvas-soft hover:text-ink">
              {category.label}
            </a>
          ))
        }
        <a href="/all-converters/" class="rounded-sm px-sm py-xs text-body-sm-strong text-ink hover:bg-canvas-soft">
          Browse all
        </a>
      </nav>
    </details>
  </div>
</header>
