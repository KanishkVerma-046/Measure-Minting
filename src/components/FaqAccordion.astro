---
interface Props {
  faqs: { question: string; answer: string }[];
}

const { faqs } = Astro.props;
---

<div class="flex flex-col gap-xs">
  {
    faqs.map((faq) => (
      <details class="group rounded-md border border-hairline bg-canvas px-md py-sm">
        <summary class="flex cursor-pointer list-none items-center justify-between text-body-md-strong text-ink [&::-webkit-details-marker]:hidden">
          {faq.question}
          <span class="ml-sm shrink-0 text-mute transition-transform group-open:rotate-45" aria-hidden="true">+</span>
        </summary>
        <p class="mt-xs text-body-md text-body">{faq.answer}</p>
      </details>
    ))
  }
</div>
