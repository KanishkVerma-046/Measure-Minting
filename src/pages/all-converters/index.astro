---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import JsonLd from "../../components/JsonLd.astro";
import { CATEGORIES } from "../../lib/units";
import { categoryPath, pairToLinkItem } from "../../lib/paths";
import { breadcrumbJsonLd } from "../../lib/seo";

const path = "/all-converters/";
const breadcrumbItems = [
  { label: "Home", path: "/" },
  { label: "All Converters", path },
];
---

<BaseLayout
  title="All Converters"
  description="Browse every unit conversion category and conversion pair on MeasureMinting."
  path={path}
>
  <JsonLd data={breadcrumbJsonLd(breadcrumbItems)} />

  <section class="px-md py-4xl sm:px-lg">
    <div class="mx-auto max-w-[1400px]">
      <div class="mb-lg">
        <Breadcrumbs items={breadcrumbItems} />
      </div>

      <h1 class="text-display-xl text-ink">All converters</h1>
      <p class="mt-sm max-w-[60ch] text-body-lg text-body">
        Every conversion category and curated unit pair on MeasureMinting, in one place.
      </p>

      <div class="mt-3xl flex flex-col gap-3xl">
        {
          CATEGORIES.map((category) => (
            <div>
              <a href={categoryPath(category.id)} class="text-display-md text-ink hover:underline">
                {category.label}
              </a>
              <p class="mt-xxs text-body-md text-body">{category.description}</p>
              <div class="mt-sm flex flex-wrap gap-xs">
                {category.popularPairs.map((pair: { from: string; to: string }) => {
                  const { label, path: pairHref } = pairToLinkItem(category, pair);
                  return (
                    <a
                      href={pairHref}
                      class="group inline-flex items-center gap-xs rounded-md border border-hairline bg-canvas px-sm py-xs text-body-sm text-body shadow-level-1 transition-all hover:border-link hover:text-link hover:shadow-level-3"
                    >
                      {label}
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="opacity-30 transition-opacity group-hover:opacity-100"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                  );
                })}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
