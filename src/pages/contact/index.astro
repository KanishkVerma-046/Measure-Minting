---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

const path = "/contact/";
const breadcrumbItems = [
  { label: "Home", path: "/" },
  { label: "Contact", path },
];
---

<BaseLayout
  title="Contact Us — MeasureMinting"
  description="Get in touch with the MeasureMinting team. Report a bug, suggest a converter, or ask a question."
  path={path}
>
  <section class="px-md py-4xl sm:px-lg">
    <div class="mx-auto max-w-[42rem]">
      <div class="mb-lg">
        <Breadcrumbs items={breadcrumbItems} />
      </div>

      <h1 class="text-display-xl text-ink text-balance">Contact Us</h1>
      <p class="mt-md text-body-lg text-body text-pretty">
        Have a question, found a bug, or want to suggest a new converter or calculator? We'd love to hear from you.
      </p>

      <form
        class="mt-2xl space-y-lg"
        action="https://formspree.io/f/your-form-id"
        method="POST"
      >
        <div class="grid gap-lg sm:grid-cols-2">
          <div class="flex flex-col gap-xs">
            <label for="name" class="text-body-sm-strong text-ink">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              placeholder="Your name"
              class="rounded-lg border border-hairline bg-canvas px-sm py-xs text-body-md text-ink placeholder:text-mute focus:border-link focus:outline-none focus:ring-2 focus:ring-link/20"
            />
          </div>
          <div class="flex flex-col gap-xs">
            <label for="email" class="text-body-sm-strong text-ink">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="you@example.com"
              class="rounded-lg border border-hairline bg-canvas px-sm py-xs text-body-md text-ink placeholder:text-mute focus:border-link focus:outline-none focus:ring-2 focus:ring-link/20"
            />
          </div>
        </div>

        <div class="flex flex-col gap-xs">
          <label for="subject" class="text-body-sm-strong text-ink">Subject</label>
          <select
            id="subject"
            name="subject"
            class="rounded-lg border border-hairline bg-canvas px-sm py-xs text-body-md text-ink focus:border-link focus:outline-none focus:ring-2 focus:ring-link/20"
          >
            <option value="general">General question</option>
            <option value="bug">Bug report</option>
            <option value="suggestion">Feature or converter suggestion</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="flex flex-col gap-xs">
          <label for="message" class="text-body-sm-strong text-ink">Message</label>
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            placeholder="Tell us what's on your mind…"
            class="rounded-lg border border-hairline bg-canvas px-sm py-xs text-body-md text-ink placeholder:text-mute focus:border-link focus:outline-none focus:ring-2 focus:ring-link/20 resize-y"
          ></textarea>
        </div>

        <button
          type="submit"
          class="btn-gradient inline-flex items-center rounded-xl px-lg py-sm text-button-lg font-medium text-white"
        >
          Send message
        </button>
      </form>

      <div class="mt-3xl border-t border-hairline pt-2xl">
        <h2 class="text-display-sm text-ink">Other ways to reach us</h2>
        <div class="mt-md space-y-sm text-body-md text-body">
          <p>
            <span class="text-body-sm-strong text-ink">Response time: </span>We aim to reply within 1–2 business days.
          </p>
          <p>
            <span class="text-body-sm-strong text-ink">Bug reports: </span>Please include the unit category, the values you entered, and the result you expected vs. what you saw.
          </p>
          <p>
            <span class="text-body-sm-strong text-ink">Feature suggestions: </span>We love hearing what converters or calculators would be useful — keep them coming.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
