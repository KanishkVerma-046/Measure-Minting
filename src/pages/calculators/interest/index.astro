---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout title="Interest Calculator — Simple Interest | MeasureMinting" description="Calculate simple interest on any principal amount with annual rate and time period." path="/calculators/interest/">
  <div class="calc-hero px-md py-2xl sm:py-3xl sm:px-lg">
    <div class="mx-auto max-w-[1400px] text-center">
      <div class="mx-auto mb-md inline-flex items-center rounded-full bg-link-bg-soft px-sm py-xxs text-caption font-medium text-link">Financial</div>
      <h1 class="text-display-lg text-ink">Interest Calculator</h1>
      <p class="mx-auto mt-sm max-w-[56ch] text-body-lg text-body">Calculate simple interest: I = P × r × t</p>
    </div>
  </div>
  <section class="px-md py-2xl sm:px-lg pb-section">
    <div class="mx-auto max-w-[42rem]">
      <div class="calc-card">
        <form id="si-form">
          <div class="calc-field">
            <label class="calc-label" for="si-currency">Currency</label>
            <select class="calc-select" id="si-currency">
              <option value="USD">USD – US Dollar ($)</option>
              <option value="EUR">EUR – Euro (€)</option>
              <option value="GBP">GBP – British Pound (£)</option>
              <option value="CAD">CAD – Canadian Dollar (C$)</option>
              <option value="AUD">AUD – Australian Dollar (A$)</option>
              <option value="CHF">CHF – Swiss Franc (Fr.)</option>
              <option value="JPY">JPY – Japanese Yen (¥)</option>
              <option value="CNY">CNY – Chinese Yuan (¥)</option>
              <option value="INR">INR – Indian Rupee (₹)</option>
              <option value="BRL">BRL – Brazilian Real (R$)</option>
              <option value="MXN">MXN – Mexican Peso (MX$)</option>
              <option value="KRW">KRW – South Korean Won (₩)</option>
              <option value="SGD">SGD – Singapore Dollar (S$)</option>
              <option value="HKD">HKD – Hong Kong Dollar (HK$)</option>
            </select>
          </div>
          <div class="calc-field">
            <label class="calc-label" for="si-principal">Principal Amount ($)</label>
            <input class="calc-input" id="si-principal" type="number" min="0" step="100" placeholder="10000">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="si-rate">Annual Interest Rate (%)</label>
            <input class="calc-input" id="si-rate" type="number" step="0.01" min="0" placeholder="5.0">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="si-years">Time Period (years)</label>
            <input class="calc-input" id="si-years" type="number" min="0" step="0.5" placeholder="3">
          </div>
          <button type="submit" class="calc-btn btn-gradient text-white">Calculate Interest</button>
        </form>
        <div id="si-result" class="calc-result hidden">
          <div class="text-center mb-md">
            <div class="text-caption text-mute mb-xxs">Simple Interest</div>
            <div id="si-interest" class="calc-result-primary"></div>
          </div>
          <div class="calc-result-row"><span class="calc-result-label">Principal</span><span id="si-r-principal" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Total amount (P + I)</span><span id="si-r-total" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Daily interest</span><span id="si-daily" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Monthly interest</span><span id="si-monthly" class="calc-result-value"></span></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const CURR_SYMBOLS: Record<string, string> = {
    USD: '$', EUR: '€', GBP: '£', CAD: 'C$', AUD: 'A$', CHF: 'Fr.',
    JPY: '¥', CNY: '¥', INR: '₹', BRL: 'R$', MXN: 'MX$', KRW: '₩',
    SGD: 'S$', HKD: 'HK$'
  };
  const origLabels = new Map<Element, string>();
  document.querySelectorAll('.calc-label').forEach(el => {
    if (el.textContent?.includes('$')) origLabels.set(el, el.textContent!);
  });
  document.getElementById('si-currency')!.addEventListener('change', () => {
    const sym = CURR_SYMBOLS[(document.getElementById('si-currency') as HTMLSelectElement).value] ?? '$';
    origLabels.forEach((orig, el) => { el.textContent = orig.replace(/\$/g, sym); });
  });

  document.getElementById('si-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const currCode = (document.getElementById('si-currency') as HTMLSelectElement).value;
    const fmt = (v: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: currCode }).format(v);
    const P = parseFloat((document.getElementById('si-principal') as HTMLInputElement).value);
    const r = parseFloat((document.getElementById('si-rate') as HTMLInputElement).value) / 100;
    const t = parseFloat((document.getElementById('si-years') as HTMLInputElement).value);

    if (!P || isNaN(r) || !t) return;

    const I = P * r * t;
    document.getElementById('si-interest')!.textContent = fmt(I);
    document.getElementById('si-r-principal')!.textContent = fmt(P);
    document.getElementById('si-r-total')!.textContent = fmt(P + I);
    document.getElementById('si-daily')!.textContent = fmt(I / (t * 365));
    document.getElementById('si-monthly')!.textContent = fmt(I / (t * 12));

    const result = document.getElementById('si-result')!;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
