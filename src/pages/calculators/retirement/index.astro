---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout title="Retirement Calculator — Savings Projection | MeasureMinting" description="Project your retirement savings and see how long your nest egg will last." path="/calculators/retirement/">
  <div class="calc-hero px-md py-2xl sm:py-3xl sm:px-lg">
    <div class="mx-auto max-w-[1400px] text-center">
      <div class="mx-auto mb-md inline-flex items-center rounded-full bg-link-bg-soft px-sm py-xxs text-caption font-medium text-link">Financial</div>
      <h1 class="text-display-lg text-ink">Retirement Calculator</h1>
      <p class="mx-auto mt-sm max-w-[56ch] text-body-lg text-body">Project your retirement savings and estimate how long your nest egg will last.</p>
    </div>
  </div>
  <section class="px-md py-2xl sm:px-lg pb-section">
    <div class="mx-auto max-w-[42rem]">
      <div class="calc-card">
        <form id="ret-form">
          <div class="calc-field">
            <label class="calc-label" for="ret-currency">Currency</label>
            <select class="calc-select" id="ret-currency">
              <option value="USD">USD – US Dollar ($)</option>
              <option value="EUR">EUR – Euro (€)</option>
              <option value="GBP">GBP – British Pound (£)</option>
              <option value="CAD">CAD – Canadian Dollar (C$)</option>
              <option value="AUD">AUD – Australian Dollar (A$)</option>
              <option value="CHF">CHF – Swiss Franc (Fr.)</option>
              <option value="JPY">JPY – Japanese Yen (¥)</option>
              <option value="CNY">CNY – Chinese Yuan (¥)</option>
              <option value="INR">INR – Indian Rupee (₹)</option>
              <option value="BRL">BRL – Brazilian Real (R$)</option>
              <option value="MXN">MXN – Mexican Peso (MX$)</option>
              <option value="KRW">KRW – South Korean Won (₩)</option>
              <option value="SGD">SGD – Singapore Dollar (S$)</option>
              <option value="HKD">HKD – Hong Kong Dollar (HK$)</option>
            </select>
          </div>
          <div class="calc-field">
            <label class="calc-label" for="ret-age">Current Age</label>
            <input class="calc-input" id="ret-age" type="number" min="18" max="100" placeholder="30">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="ret-retire-age">Retirement Age</label>
            <input class="calc-input" id="ret-retire-age" type="number" min="40" max="100" placeholder="65">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="ret-current">Current Savings ($)</label>
            <input class="calc-input" id="ret-current" type="number" min="0" step="1000" placeholder="50000">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="ret-monthly">Monthly Contribution ($)</label>
            <input class="calc-input" id="ret-monthly" type="number" min="0" step="100" placeholder="1000">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="ret-return">Expected Annual Return (%)</label>
            <input class="calc-input" id="ret-return" type="number" step="0.1" min="0" placeholder="7.0">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="ret-withdrawal">Monthly Withdrawal in Retirement ($)</label>
            <input class="calc-input" id="ret-withdrawal" type="number" min="0" step="100" placeholder="4000">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="ret-post-return">Post-retirement Return (%)</label>
            <input class="calc-input" id="ret-post-return" type="number" step="0.1" min="0" placeholder="4.0">
          </div>
          <button type="submit" class="calc-btn btn-gradient text-white">Calculate Retirement</button>
        </form>
        <div id="ret-result" class="calc-result hidden">
          <div class="text-center mb-md">
            <div class="text-caption text-mute mb-xxs">Nest Egg at Retirement</div>
            <div id="ret-nest" class="calc-result-primary"></div>
          </div>
          <div class="calc-result-row"><span class="calc-result-label">Years to retirement</span><span id="ret-years" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Savings will last until age</span><span id="ret-until" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Total contributions</span><span id="ret-total-contrib" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Investment gains</span><span id="ret-gains" class="calc-result-value" style="color:var(--color-success)"></span></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const CURR_SYMBOLS: Record<string, string> = {
    USD: '$', EUR: '€', GBP: '£', CAD: 'C$', AUD: 'A$', CHF: 'Fr.',
    JPY: '¥', CNY: '¥', INR: '₹', BRL: 'R$', MXN: 'MX$', KRW: '₩',
    SGD: 'S$', HKD: 'HK$'
  };
  const origLabels = new Map<Element, string>();
  document.querySelectorAll('.calc-label').forEach(el => {
    if (el.textContent?.includes('$')) origLabels.set(el, el.textContent!);
  });
  document.getElementById('ret-currency')!.addEventListener('change', () => {
    const sym = CURR_SYMBOLS[(document.getElementById('ret-currency') as HTMLSelectElement).value] ?? '$';
    origLabels.forEach((orig, el) => { el.textContent = orig.replace(/\$/g, sym); });
  });

  document.getElementById('ret-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const currCode = (document.getElementById('ret-currency') as HTMLSelectElement).value;
    const fmt = (v: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: currCode, maximumFractionDigits: 0 }).format(v);
    const age = parseInt((document.getElementById('ret-age') as HTMLInputElement).value);
    const retireAge = parseInt((document.getElementById('ret-retire-age') as HTMLInputElement).value);
    const current = parseFloat((document.getElementById('ret-current') as HTMLInputElement).value) || 0;
    const monthly = parseFloat((document.getElementById('ret-monthly') as HTMLInputElement).value) || 0;
    const rate = parseFloat((document.getElementById('ret-return') as HTMLInputElement).value);
    const withdrawal = parseFloat((document.getElementById('ret-withdrawal') as HTMLInputElement).value) || 0;
    const postRate = parseFloat((document.getElementById('ret-post-return') as HTMLInputElement).value) || 4;

    if (!age || !retireAge || retireAge <= age || !rate) return;

    const yearsToRetire = retireAge - age;
    const r = rate / 100 / 12;
    const n = yearsToRetire * 12;
    const nestEgg = current * Math.pow(1 + r, n) + (r > 0 ? monthly * (Math.pow(1 + r, n) - 1) / r : monthly * n);
    const totalContrib = monthly * n;
    const gains = nestEgg - current - totalContrib;

    let balance = nestEgg;
    const rPost = postRate / 100 / 12;
    let months = 0;
    if (withdrawal > 0) {
      while (balance > 0 && months < 600) {
        balance = balance * (1 + rPost) - withdrawal;
        months++;
      }
    }
    const lasts = months >= 600 ? '99+' : (retireAge + Math.floor(months / 12)).toString();

    document.getElementById('ret-nest')!.textContent = fmt(nestEgg);
    document.getElementById('ret-years')!.textContent = yearsToRetire + ' years';
    document.getElementById('ret-until')!.textContent = 'Age ' + lasts;
    document.getElementById('ret-total-contrib')!.textContent = fmt(totalContrib);
    document.getElementById('ret-gains')!.textContent = fmt(gains);

    const result = document.getElementById('ret-result')!;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
