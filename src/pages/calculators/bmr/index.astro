---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout title="BMR Calculator — Basal Metabolic Rate | MeasureMinting" description="Calculate your Basal Metabolic Rate (BMR) — the calories your body burns at complete rest." path="/calculators/bmr/">
  <div class="calc-hero px-md py-2xl sm:py-3xl sm:px-lg">
    <div class="mx-auto max-w-[1400px] text-center">
      <div class="mx-auto mb-md inline-flex items-center rounded-full bg-link-bg-soft px-sm py-xxs text-caption font-medium text-link">Health & Fitness</div>
      <h1 class="text-display-lg text-ink">BMR Calculator</h1>
      <p class="mx-auto mt-sm max-w-[56ch] text-body-lg text-body">Calculate your Basal Metabolic Rate — calories burned at complete rest using the Mifflin-St Jeor equation.</p>
    </div>
  </div>
  <section class="px-md py-2xl sm:px-lg pb-section">
    <div class="mx-auto max-w-[42rem]">
      <div class="calc-card">
        <form id="bmr-form">
          <div class="mb-md flex gap-sm">
            <label class="flex items-center gap-xs text-body-sm cursor-pointer"><input type="radio" name="system" value="metric" checked class="accent-link"> Metric</label>
            <label class="flex items-center gap-xs text-body-sm cursor-pointer"><input type="radio" name="system" value="imperial" class="accent-link"> Imperial</label>
          </div>
          <div class="mb-md flex gap-sm">
            <label class="flex items-center gap-xs text-body-sm cursor-pointer"><input type="radio" name="sex" value="male" checked class="accent-link"> Male</label>
            <label class="flex items-center gap-xs text-body-sm cursor-pointer"><input type="radio" name="sex" value="female" class="accent-link"> Female</label>
          </div>
          <div class="calc-field">
            <label class="calc-label" for="age">Age (years)</label>
            <input class="calc-input" id="age" type="number" min="15" max="100" placeholder="30">
          </div>
          <div id="metric-fields">
            <div class="calc-field">
              <label class="calc-label" for="weight-kg">Weight (kg)</label>
              <input class="calc-input" id="weight-kg" type="number" step="0.1" placeholder="70">
            </div>
            <div class="calc-field">
              <label class="calc-label" for="height-cm">Height (cm)</label>
              <input class="calc-input" id="height-cm" type="number" step="0.1" placeholder="175">
            </div>
          </div>
          <div id="imperial-fields" class="hidden">
            <div class="calc-field">
              <label class="calc-label" for="weight-lb">Weight (lbs)</label>
              <input class="calc-input" id="weight-lb" type="number" step="0.1" placeholder="154">
            </div>
            <div class="flex gap-sm">
              <div class="calc-field flex-1"><label class="calc-label" for="height-ft">Height (ft)</label><input class="calc-input" id="height-ft" type="number" placeholder="5"></div>
              <div class="calc-field flex-1"><label class="calc-label" for="height-in">Height (in)</label><input class="calc-input" id="height-in" type="number" step="0.1" placeholder="9"></div>
            </div>
          </div>
          <button type="submit" class="calc-btn btn-gradient text-white">Calculate BMR</button>
        </form>
        <div id="bmr-result" class="calc-result hidden">
          <div class="text-center mb-md">
            <div class="text-caption text-mute mb-xxs">Basal Metabolic Rate</div>
            <div id="bmr-value" class="calc-result-primary"></div>
            <div class="text-body-sm text-body mt-xxs">calories / day</div>
          </div>
          <div class="calc-result-row"><span class="calc-result-label">Sedentary (desk job)</span><span id="act-1" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Light exercise (1–3×/wk)</span><span id="act-2" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Moderate exercise (3–5×/wk)</span><span id="act-3" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Heavy exercise (6–7×/wk)</span><span id="act-4" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Very heavy (athlete/physical job)</span><span id="act-5" class="calc-result-value"></span></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('bmr-form') as HTMLFormElement;
  document.querySelectorAll('input[name="system"]').forEach(r => {
    r.addEventListener('change', (e) => {
      const isMetric = (e.target as HTMLInputElement).value === 'metric';
      document.getElementById('metric-fields')!.classList.toggle('hidden', !isMetric);
      document.getElementById('imperial-fields')!.classList.toggle('hidden', isMetric);
    });
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const isMetric = (document.querySelector('input[name="system"]:checked') as HTMLInputElement).value === 'metric';
    const isMale = (document.querySelector('input[name="sex"]:checked') as HTMLInputElement).value === 'male';
    const age = parseFloat((document.getElementById('age') as HTMLInputElement).value);
    let weightKg: number, heightCm: number;

    if (isMetric) {
      weightKg = parseFloat((document.getElementById('weight-kg') as HTMLInputElement).value);
      heightCm = parseFloat((document.getElementById('height-cm') as HTMLInputElement).value);
    } else {
      weightKg = parseFloat((document.getElementById('weight-lb') as HTMLInputElement).value) * 0.453592;
      const ft = parseFloat((document.getElementById('height-ft') as HTMLInputElement).value) || 0;
      const inch = parseFloat((document.getElementById('height-in') as HTMLInputElement).value) || 0;
      heightCm = (ft * 12 + inch) * 2.54;
    }

    if (!weightKg || !heightCm || !age) return;

    // Mifflin-St Jeor
    const bmr = isMale
      ? 10 * weightKg + 6.25 * heightCm - 5 * age + 5
      : 10 * weightKg + 6.25 * heightCm - 5 * age - 161;

    document.getElementById('bmr-value')!.textContent = Math.round(bmr).toLocaleString() + ' kcal';
    document.getElementById('act-1')!.textContent = Math.round(bmr * 1.2).toLocaleString() + ' kcal';
    document.getElementById('act-2')!.textContent = Math.round(bmr * 1.375).toLocaleString() + ' kcal';
    document.getElementById('act-3')!.textContent = Math.round(bmr * 1.55).toLocaleString() + ' kcal';
    document.getElementById('act-4')!.textContent = Math.round(bmr * 1.725).toLocaleString() + ' kcal';
    document.getElementById('act-5')!.textContent = Math.round(bmr * 1.9).toLocaleString() + ' kcal';

    const result = document.getElementById('bmr-result')!;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
