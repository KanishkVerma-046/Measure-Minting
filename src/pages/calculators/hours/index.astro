---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout title="Hours Calculator — Work Hours & Pay | MeasureMinting" description="Calculate total work hours and pay from start and end times for multiple days." path="/calculators/hours/">
  <div class="calc-hero px-md py-2xl sm:py-3xl sm:px-lg">
    <div class="mx-auto max-w-[1400px] text-center">
      <div class="mx-auto mb-md inline-flex items-center rounded-full bg-link-bg-soft px-sm py-xxs text-caption font-medium text-link">Other</div>
      <h1 class="text-display-lg text-ink">Hours Calculator</h1>
      <p class="mx-auto mt-sm max-w-[56ch] text-body-lg text-body">Calculate total work hours and earnings from time ranges across multiple days.</p>
    </div>
  </div>
  <section class="px-md py-2xl sm:px-lg pb-section">
    <div class="mx-auto max-w-[42rem]">
      <div class="calc-card">
        <div class="overflow-x-auto">
          <table class="w-full text-body-sm mb-md">
            <thead>
              <tr class="border-b border-hairline">
                <th class="text-left py-xs pr-sm font-medium text-ink">Day</th>
                <th class="text-left py-xs px-xs font-medium text-ink">Start</th>
                <th class="text-left py-xs px-xs font-medium text-ink">End</th>
                <th class="text-left py-xs px-xs font-medium text-ink">Break (min)</th>
                <th class="text-right py-xs font-medium text-ink">Hours</th>
              </tr>
            </thead>
            <tbody id="hours-tbody">
            </tbody>
          </table>
        </div>
        <div class="flex gap-sm mb-lg">
          <button id="add-day" type="button" class="inline-flex items-center gap-xs rounded-xl border border-hairline bg-canvas px-md py-xs text-body-sm-strong hover:bg-link-bg-soft hover:border-link hover:text-link transition-colors">
            + Add day
          </button>
        </div>
        <div class="calc-field">
          <label class="calc-label" for="hourly-rate">Hourly Rate ($ optional)</label>
          <input class="calc-input" id="hourly-rate" type="number" step="0.01" min="0" placeholder="15.00">
        </div>
        <button id="calc-hours" type="button" class="calc-btn btn-gradient text-white">Calculate Hours</button>

        <div id="hours-result" class="calc-result hidden">
          <div class="text-center mb-md">
            <div class="text-caption text-mute mb-xxs">Total Hours</div>
            <div id="total-hours-val" class="calc-result-primary"></div>
          </div>
          <div class="calc-result-row"><span class="calc-result-label">Total pay</span><span id="total-pay" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Average hours/day</span><span id="avg-hours" class="calc-result-value"></span></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const days = ['Monday','Tuesday','Wednesday','Thursday','Friday'];
  const tbody = document.getElementById('hours-tbody')!;

  function addRow(label = '') {
    const tr = document.createElement('tr');
    tr.className = 'hours-row border-b border-hairline';
    tr.innerHTML = `
      <td class="py-xs pr-sm text-body-sm text-body">${label || 'Day'}</td>
      <td class="py-xs px-xs"><input type="time" class="calc-input start-time" style="padding:6px 10px"></td>
      <td class="py-xs px-xs"><input type="time" class="calc-input end-time" style="padding:6px 10px"></td>
      <td class="py-xs px-xs"><input type="number" class="calc-input break-min" min="0" max="480" placeholder="0" style="padding:6px 10px;width:70px"></td>
      <td class="py-xs text-right font-medium row-hours">—</td>
    `;
    tbody.appendChild(tr);
    tr.querySelectorAll('input').forEach(inp => inp.addEventListener('change', updateRowHours));
  }

  function updateRowHours() {
    tbody.querySelectorAll('.hours-row').forEach(row => {
      const start = (row.querySelector('.start-time') as HTMLInputElement).value;
      const end = (row.querySelector('.end-time') as HTMLInputElement).value;
      const brk = parseFloat((row.querySelector('.break-min') as HTMLInputElement).value) || 0;
      if (start && end) {
        const toM = (t: string) => { const [h,m] = t.split(':'); return parseInt(h)*60+parseInt(m); };
        let mins = toM(end) - toM(start) - brk;
        if (mins < 0) mins += 1440;
        (row.querySelector('.row-hours') as HTMLElement).textContent = (mins / 60).toFixed(2) + 'h';
      }
    });
  }

  days.forEach(d => addRow(d));

  document.getElementById('add-day')!.addEventListener('click', () => addRow());

  document.getElementById('calc-hours')!.addEventListener('click', () => {
    const toM = (t: string) => { const [h,m] = t.split(':'); return parseInt(h)*60+parseInt(m); };
    let total = 0, count = 0;
    tbody.querySelectorAll('.hours-row').forEach(row => {
      const start = (row.querySelector('.start-time') as HTMLInputElement).value;
      const end = (row.querySelector('.end-time') as HTMLInputElement).value;
      const brk = parseFloat((row.querySelector('.break-min') as HTMLInputElement).value) || 0;
      if (start && end) {
        let mins = toM(end) - toM(start) - brk;
        if (mins < 0) mins += 1440;
        total += mins;
        count++;
      }
    });

    const totalHours = total / 60;
    const rate = parseFloat((document.getElementById('hourly-rate') as HTMLInputElement).value) || 0;

    document.getElementById('total-hours-val')!.textContent = totalHours.toFixed(2) + ' hours';
    document.getElementById('total-pay')!.textContent = rate > 0 ? '$' + (totalHours * rate).toFixed(2) : 'N/A (enter hourly rate)';
    document.getElementById('avg-hours')!.textContent = count > 0 ? (totalHours / count).toFixed(2) + 'h/day' : '—';

    const result = document.getElementById('hours-result')!;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
