---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout title="Interest Rate Calculator — Find Unknown Rate | MeasureMinting" description="Calculate the unknown interest rate from loan principal, payment amount, and term using Newton's method." path="/calculators/interest-rate/">
  <div class="calc-hero px-md py-2xl sm:py-3xl sm:px-lg">
    <div class="mx-auto max-w-[1400px] text-center">
      <div class="mx-auto mb-md inline-flex items-center rounded-full bg-link-bg-soft px-sm py-xxs text-caption font-medium text-link">Financial</div>
      <h1 class="text-display-lg text-ink">Interest Rate Calculator</h1>
      <p class="mx-auto mt-sm max-w-[56ch] text-body-lg text-body">Find the exact interest rate from your loan details.</p>
    </div>
  </div>
  <section class="px-md py-2xl sm:px-lg pb-section">
    <div class="mx-auto max-w-[42rem]">
      <div class="calc-card">
        <form id="ir-form">
          <div class="calc-field">
            <label class="calc-label" for="ir-currency">Currency</label>
            <select class="calc-select" id="ir-currency">
              <option value="USD">USD – US Dollar ($)</option>
              <option value="EUR">EUR – Euro (€)</option>
              <option value="GBP">GBP – British Pound (£)</option>
              <option value="CAD">CAD – Canadian Dollar (C$)</option>
              <option value="AUD">AUD – Australian Dollar (A$)</option>
              <option value="CHF">CHF – Swiss Franc (Fr.)</option>
              <option value="JPY">JPY – Japanese Yen (¥)</option>
              <option value="CNY">CNY – Chinese Yuan (¥)</option>
              <option value="INR">INR – Indian Rupee (₹)</option>
              <option value="BRL">BRL – Brazilian Real (R$)</option>
              <option value="MXN">MXN – Mexican Peso (MX$)</option>
              <option value="KRW">KRW – South Korean Won (₩)</option>
              <option value="SGD">SGD – Singapore Dollar (S$)</option>
              <option value="HKD">HKD – Hong Kong Dollar (HK$)</option>
            </select>
          </div>
          <div class="calc-field">
            <label class="calc-label" for="ir-principal">Loan Amount ($)</label>
            <input class="calc-input" id="ir-principal" type="number" min="0" step="500" placeholder="20000">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="ir-payment">Monthly Payment ($)</label>
            <input class="calc-input" id="ir-payment" type="number" step="0.01" min="0" placeholder="400">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="ir-months">Loan Term (months)</label>
            <input class="calc-input" id="ir-months" type="number" min="1" placeholder="60">
          </div>
          <button type="submit" class="calc-btn btn-gradient text-white">Find Interest Rate</button>
        </form>
        <div id="ir-result" class="calc-result hidden">
          <div class="text-center mb-md">
            <div class="text-caption text-mute mb-xxs">Annual Interest Rate</div>
            <div id="ir-rate" class="calc-result-primary"></div>
          </div>
          <div class="calc-result-row"><span class="calc-result-label">Monthly rate</span><span id="ir-monthly-rate" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Total payments</span><span id="ir-total" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Total interest</span><span id="ir-interest" class="calc-result-value"></span></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const CURR_SYMBOLS: Record<string, string> = {
    USD: '$', EUR: '€', GBP: '£', CAD: 'C$', AUD: 'A$', CHF: 'Fr.',
    JPY: '¥', CNY: '¥', INR: '₹', BRL: 'R$', MXN: 'MX$', KRW: '₩',
    SGD: 'S$', HKD: 'HK$'
  };
  const origLabels = new Map<Element, string>();
  document.querySelectorAll('.calc-label').forEach(el => {
    if (el.textContent?.includes('$')) origLabels.set(el, el.textContent!);
  });
  document.getElementById('ir-currency')!.addEventListener('change', () => {
    const sym = CURR_SYMBOLS[(document.getElementById('ir-currency') as HTMLSelectElement).value] ?? '$';
    origLabels.forEach((orig, el) => { el.textContent = orig.replace(/\$/g, sym); });
  });

  document.getElementById('ir-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const currCode = (document.getElementById('ir-currency') as HTMLSelectElement).value;
    const fmt = (v: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: currCode }).format(v);
    const P = parseFloat((document.getElementById('ir-principal') as HTMLInputElement).value);
    const PMT = parseFloat((document.getElementById('ir-payment') as HTMLInputElement).value);
    const n = parseInt((document.getElementById('ir-months') as HTMLInputElement).value);

    if (!P || !PMT || !n) return;

    let r = 0.005;
    for (let i = 0; i < 200; i++) {
      const pow = Math.pow(1 + r, n);
      const f = P * r * pow / (pow - 1) - PMT;
      const df = P * (pow * (1 + r * n) - 1) / Math.pow(pow - 1, 2);
      const newR = r - f / df;
      if (Math.abs(newR - r) < 1e-10) { r = newR; break; }
      r = newR;
    }

    const annualRate = r * 12 * 100;
    const total = PMT * n;
    const interest = total - P;

    document.getElementById('ir-rate')!.textContent = annualRate.toFixed(3) + '%';
    document.getElementById('ir-monthly-rate')!.textContent = (r * 100).toFixed(4) + '%';
    document.getElementById('ir-total')!.textContent = fmt(total);
    document.getElementById('ir-interest')!.textContent = fmt(interest);

    const result = document.getElementById('ir-result')!;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
