---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout title="Compound Interest Calculator | MeasureMinting" description="Calculate compound interest growth with optional regular contributions. See how your money grows over time." path="/calculators/compound-interest/">
  <div class="calc-hero px-md py-2xl sm:py-3xl sm:px-lg">
    <div class="mx-auto max-w-[1400px] text-center">
      <div class="mx-auto mb-md inline-flex items-center rounded-full bg-link-bg-soft px-sm py-xxs text-caption font-medium text-link">Financial</div>
      <h1 class="text-display-lg text-ink">Compound Interest Calculator</h1>
      <p class="mx-auto mt-sm max-w-[56ch] text-body-lg text-body">See how your investment grows with compound interest and regular contributions.</p>
    </div>
  </div>
  <section class="px-md py-2xl sm:px-lg pb-section">
    <div class="mx-auto max-w-[42rem]">
      <div class="calc-card">
        <form id="ci-form">
          <div class="calc-field">
            <label class="calc-label" for="principal">Initial Investment ($)</label>
            <input class="calc-input" id="principal" type="number" min="0" step="100" placeholder="10000">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="contribution">Monthly Contribution ($)</label>
            <input class="calc-input" id="contribution" type="number" min="0" step="50" placeholder="500">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="annual-rate">Annual Interest Rate (%)</label>
            <input class="calc-input" id="annual-rate" type="number" step="0.01" min="0" placeholder="7.0">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="years">Time Period (years)</label>
            <input class="calc-input" id="years" type="number" min="1" max="100" placeholder="30">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="compound-freq">Compound Frequency</label>
            <select class="calc-select" id="compound-freq">
              <option value="12">Monthly</option>
              <option value="4">Quarterly</option>
              <option value="2">Semi-annually</option>
              <option value="1">Annually</option>
              <option value="365">Daily</option>
            </select>
          </div>
          <button type="submit" class="calc-btn btn-gradient text-white">Calculate Growth</button>
        </form>
        <div id="ci-result" class="calc-result hidden">
          <div class="text-center mb-md">
            <div class="text-caption text-mute mb-xxs">Final Balance</div>
            <div id="final-balance" class="calc-result-primary"></div>
          </div>
          <div class="calc-result-row"><span class="calc-result-label">Initial investment</span><span id="r-principal" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Total contributions</span><span id="r-contributions" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Interest earned</span><span id="r-interest" class="calc-result-value" style="color:var(--color-success)"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Total invested</span><span id="r-invested" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Return on investment</span><span id="r-roi" class="calc-result-value"></span></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.getElementById('ci-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const P = parseFloat((document.getElementById('principal') as HTMLInputElement).value) || 0;
    const PMT = parseFloat((document.getElementById('contribution') as HTMLInputElement).value) || 0;
    const r = parseFloat((document.getElementById('annual-rate') as HTMLInputElement).value);
    const years = parseInt((document.getElementById('years') as HTMLInputElement).value);
    const n = parseInt((document.getElementById('compound-freq') as HTMLSelectElement).value);

    if (!r || !years) return;

    const rn = r / 100 / n;
    const periods = n * years;

    // Future value of lump sum + future value of annuity (monthly contrib normalized to compound periods)
    const FV_principal = P * Math.pow(1 + rn, periods);
    const monthlyPeriods = 12 * years;
    // Simulate month by month for accuracy with different compound frequencies
    let balance = P;
    for (let m = 1; m <= monthlyPeriods; m++) {
      balance += PMT;
      // Apply compound interest at each compound period that falls on this month
      const compoundsThisMonth = n / 12;
      balance *= Math.pow(1 + rn, compoundsThisMonth);
    }

    const totalContrib = PMT * monthlyPeriods;
    const totalInvested = P + totalContrib;
    const interestEarned = balance - totalInvested;
    const roi = (interestEarned / totalInvested) * 100;

    const fmt = (v: number) => '$' + Math.round(v).toLocaleString('en-US');
    document.getElementById('final-balance')!.textContent = fmt(balance);
    document.getElementById('r-principal')!.textContent = fmt(P);
    document.getElementById('r-contributions')!.textContent = fmt(totalContrib);
    document.getElementById('r-interest')!.textContent = fmt(interestEarned);
    document.getElementById('r-invested')!.textContent = fmt(totalInvested);
    document.getElementById('r-roi')!.textContent = roi.toFixed(1) + '%';

    const result = document.getElementById('ci-result')!;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
