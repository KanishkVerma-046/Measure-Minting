---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout title="Sales Tax Calculator — Price Before & After Tax | MeasureMinting" description="Calculate the total price after sales tax, or find the pre-tax price from a post-tax amount." path="/calculators/sales-tax/">
  <div class="calc-hero px-md py-2xl sm:py-3xl sm:px-lg">
    <div class="mx-auto max-w-[1400px] text-center">
      <div class="mx-auto mb-md inline-flex items-center rounded-full bg-link-bg-soft px-sm py-xxs text-caption font-medium text-link">Financial</div>
      <h1 class="text-display-lg text-ink">Sales Tax Calculator</h1>
      <p class="mx-auto mt-sm max-w-[56ch] text-body-lg text-body">Calculate price after tax, or find the pre-tax amount from a total.</p>
    </div>
  </div>
  <section class="px-md py-2xl sm:px-lg pb-section">
    <div class="mx-auto max-w-[42rem]">
      <div class="calc-card">
        <div class="mb-md flex gap-sm">
          <label class="flex items-center gap-xs text-body-sm cursor-pointer"><input type="radio" name="mode" value="add" checked class="accent-link"> Add tax to price</label>
          <label class="flex items-center gap-xs text-body-sm cursor-pointer"><input type="radio" name="mode" value="remove" class="accent-link"> Remove tax from total</label>
        </div>
        <form id="st-form">
          <div class="calc-field">
            <label class="calc-label" for="st-currency">Currency</label>
            <select class="calc-select" id="st-currency">
              <option value="USD">USD – US Dollar ($)</option>
              <option value="EUR">EUR – Euro (€)</option>
              <option value="GBP">GBP – British Pound (£)</option>
              <option value="CAD">CAD – Canadian Dollar (C$)</option>
              <option value="AUD">AUD – Australian Dollar (A$)</option>
              <option value="CHF">CHF – Swiss Franc (Fr.)</option>
              <option value="JPY">JPY – Japanese Yen (¥)</option>
              <option value="CNY">CNY – Chinese Yuan (¥)</option>
              <option value="INR">INR – Indian Rupee (₹)</option>
              <option value="BRL">BRL – Brazilian Real (R$)</option>
              <option value="MXN">MXN – Mexican Peso (MX$)</option>
              <option value="KRW">KRW – South Korean Won (₩)</option>
              <option value="SGD">SGD – Singapore Dollar (S$)</option>
              <option value="HKD">HKD – Hong Kong Dollar (HK$)</option>
            </select>
          </div>
          <div class="calc-field" id="pretax-field">
            <label class="calc-label" for="st-price">Price Before Tax ($)</label>
            <input class="calc-input" id="st-price" type="number" step="0.01" min="0" placeholder="99.99">
          </div>
          <div class="calc-field hidden" id="posttax-field">
            <label class="calc-label" for="st-total">Total with Tax ($)</label>
            <input class="calc-input" id="st-total" type="number" step="0.01" min="0" placeholder="106.99">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="st-rate">Sales Tax Rate (%)</label>
            <input class="calc-input" id="st-rate" type="number" step="0.001" min="0" placeholder="7.0">
          </div>
          <button type="submit" class="calc-btn btn-gradient text-white">Calculate</button>
        </form>
        <div id="st-result" class="calc-result hidden">
          <div class="calc-result-row"><span class="calc-result-label">Pre-tax price</span><span id="st-pretax" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Tax amount</span><span id="st-taxamt" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Total (with tax)</span><span id="st-posttax" class="calc-result-primary" style="font-size:1.4rem"></span></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const CURR_SYMBOLS: Record<string, string> = {
    USD: '$', EUR: '€', GBP: '£', CAD: 'C$', AUD: 'A$', CHF: 'Fr.',
    JPY: '¥', CNY: '¥', INR: '₹', BRL: 'R$', MXN: 'MX$', KRW: '₩',
    SGD: 'S$', HKD: 'HK$'
  };
  const origLabels = new Map<Element, string>();
  document.querySelectorAll('.calc-label').forEach(el => {
    if (el.textContent?.includes('$')) origLabels.set(el, el.textContent!);
  });
  document.getElementById('st-currency')!.addEventListener('change', () => {
    const sym = CURR_SYMBOLS[(document.getElementById('st-currency') as HTMLSelectElement).value] ?? '$';
    origLabels.forEach((orig, el) => { el.textContent = orig.replace(/\$/g, sym); });
  });

  document.querySelectorAll('input[name="mode"]').forEach(r => {
    r.addEventListener('change', (e) => {
      const isAdd = (e.target as HTMLInputElement).value === 'add';
      document.getElementById('pretax-field')!.classList.toggle('hidden', !isAdd);
      document.getElementById('posttax-field')!.classList.toggle('hidden', isAdd);
    });
  });

  document.getElementById('st-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const currCode = (document.getElementById('st-currency') as HTMLSelectElement).value;
    const fmt = (v: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: currCode }).format(v);
    const mode = (document.querySelector('input[name="mode"]:checked') as HTMLInputElement).value;
    const rate = parseFloat((document.getElementById('st-rate') as HTMLInputElement).value) / 100;
    if (isNaN(rate)) return;

    let preTax: number, postTax: number;
    if (mode === 'add') {
      preTax = parseFloat((document.getElementById('st-price') as HTMLInputElement).value);
      if (!preTax) return;
      postTax = preTax * (1 + rate);
    } else {
      postTax = parseFloat((document.getElementById('st-total') as HTMLInputElement).value);
      if (!postTax) return;
      preTax = postTax / (1 + rate);
    }

    const taxAmt = postTax - preTax;
    document.getElementById('st-pretax')!.textContent = fmt(preTax);
    document.getElementById('st-taxamt')!.textContent = fmt(taxAmt);
    document.getElementById('st-posttax')!.textContent = fmt(postTax);

    const result = document.getElementById('st-result')!;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
