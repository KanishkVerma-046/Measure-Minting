---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout title="Amortization Calculator — Full Payment Schedule | MeasureMinting" description="Generate a full loan amortization schedule showing principal and interest for every payment." path="/calculators/amortization/">
  <div class="calc-hero px-md py-2xl sm:py-3xl sm:px-lg">
    <div class="mx-auto max-w-[1400px] text-center">
      <div class="mx-auto mb-md inline-flex items-center rounded-full bg-link-bg-soft px-sm py-xxs text-caption font-medium text-link">Financial</div>
      <h1 class="text-display-lg text-ink">Amortization Calculator</h1>
      <p class="mx-auto mt-sm max-w-[56ch] text-body-lg text-body">Generate a complete loan amortization schedule with payment-by-payment breakdown.</p>
    </div>
  </div>
  <section class="px-md py-2xl sm:px-lg pb-section">
    <div class="mx-auto max-w-[42rem]">
      <div class="calc-card">
        <form id="amort-form">
          <div class="calc-field">
            <label class="calc-label" for="am-principal">Loan Amount ($)</label>
            <input class="calc-input" id="am-principal" type="number" min="0" step="1000" placeholder="200000">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="am-rate">Annual Interest Rate (%)</label>
            <input class="calc-input" id="am-rate" type="number" step="0.01" min="0" placeholder="6.5">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="am-term">Loan Term (years)</label>
            <input class="calc-input" id="am-term" type="number" min="1" max="50" placeholder="30">
          </div>
          <button type="submit" class="calc-btn btn-gradient text-white">Generate Schedule</button>
        </form>
        <div id="amort-result" class="hidden">
          <div class="calc-result mt-lg">
            <div class="calc-result-row"><span class="calc-result-label">Monthly payment</span><span id="am-monthly" class="calc-result-value"></span></div>
            <div class="calc-result-row"><span class="calc-result-label">Total payments</span><span id="am-total" class="calc-result-value"></span></div>
            <div class="calc-result-row"><span class="calc-result-label">Total interest</span><span id="am-interest" class="calc-result-value"></span></div>
          </div>
          <div class="mt-lg overflow-x-auto rounded-xl border border-hairline">
            <table class="w-full text-body-sm">
              <thead>
                <tr class="border-b border-hairline bg-canvas-soft-2">
                  <th class="px-sm py-xs text-left font-medium text-ink">#</th>
                  <th class="px-sm py-xs text-right font-medium text-ink">Payment</th>
                  <th class="px-sm py-xs text-right font-medium text-ink">Principal</th>
                  <th class="px-sm py-xs text-right font-medium text-ink">Interest</th>
                  <th class="px-sm py-xs text-right font-medium text-ink">Balance</th>
                </tr>
              </thead>
              <tbody id="amort-tbody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.getElementById('amort-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const P = parseFloat((document.getElementById('am-principal') as HTMLInputElement).value);
    const rate = parseFloat((document.getElementById('am-rate') as HTMLInputElement).value);
    const years = parseInt((document.getElementById('am-term') as HTMLInputElement).value);

    if (!P || !years) return;

    const r = rate / 100 / 12;
    const n = years * 12;
    const payment = r === 0 ? P / n : P * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);

    document.getElementById('am-monthly')!.textContent = '$' + payment.toFixed(2);
    document.getElementById('am-total')!.textContent = '$' + (payment * n).toFixed(2);
    document.getElementById('am-interest')!.textContent = '$' + (payment * n - P).toFixed(2);

    const tbody = document.getElementById('amort-tbody')!;
    tbody.innerHTML = '';
    let balance = P;
    for (let i = 1; i <= n; i++) {
      const interestPmt = balance * r;
      const principalPmt = payment - interestPmt;
      balance = Math.max(0, balance - principalPmt);
      if (i <= 12 || i > n - 12 || i % 12 === 0) {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-hairline hover:bg-canvas-soft';
        tr.innerHTML = `
          <td class="px-sm py-xs text-mute">${i}</td>
          <td class="px-sm py-xs text-right">$${payment.toFixed(2)}</td>
          <td class="px-sm py-xs text-right" style="color:var(--color-success)">$${principalPmt.toFixed(2)}</td>
          <td class="px-sm py-xs text-right" style="color:var(--color-error)">$${interestPmt.toFixed(2)}</td>
          <td class="px-sm py-xs text-right font-medium">$${balance.toFixed(2)}</td>
        `;
        tbody.appendChild(tr);
      }
    }

    const result = document.getElementById('amort-result')!;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
