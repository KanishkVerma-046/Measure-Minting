---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout title="Mortgage Calculator — Monthly Payment & Interest | MeasureMinting" description="Calculate your monthly mortgage payment, total interest paid, and full amortization breakdown." path="/calculators/mortgage/">
  <div class="calc-hero px-md py-2xl sm:py-3xl sm:px-lg">
    <div class="mx-auto max-w-[1400px] text-center">
      <div class="mx-auto mb-md inline-flex items-center rounded-full bg-link-bg-soft px-sm py-xxs text-caption font-medium text-link">Financial</div>
      <h1 class="text-display-lg text-ink">Mortgage Calculator</h1>
      <p class="mx-auto mt-sm max-w-[56ch] text-body-lg text-body">Calculate your monthly mortgage payment and total cost of the loan.</p>
    </div>
  </div>
  <section class="px-md py-2xl sm:px-lg pb-section">
    <div class="mx-auto max-w-[42rem]">
      <div class="calc-card">
        <form id="mort-form">
          <div class="calc-field">
            <label class="calc-label" for="mort-currency">Currency</label>
            <select class="calc-select" id="mort-currency">
              <option value="USD">USD – US Dollar ($)</option>
              <option value="EUR">EUR – Euro (€)</option>
              <option value="GBP">GBP – British Pound (£)</option>
              <option value="CAD">CAD – Canadian Dollar (C$)</option>
              <option value="AUD">AUD – Australian Dollar (A$)</option>
              <option value="CHF">CHF – Swiss Franc (Fr.)</option>
              <option value="JPY">JPY – Japanese Yen (¥)</option>
              <option value="CNY">CNY – Chinese Yuan (¥)</option>
              <option value="INR">INR – Indian Rupee (₹)</option>
              <option value="BRL">BRL – Brazilian Real (R$)</option>
              <option value="MXN">MXN – Mexican Peso (MX$)</option>
              <option value="KRW">KRW – South Korean Won (₩)</option>
              <option value="SGD">SGD – Singapore Dollar (S$)</option>
              <option value="HKD">HKD – Hong Kong Dollar (HK$)</option>
            </select>
          </div>
          <div class="calc-field">
            <label class="calc-label" for="home-price">Home Price ($)</label>
            <input class="calc-input" id="home-price" type="number" min="0" step="1000" placeholder="400000">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="down-payment">Down Payment ($)</label>
            <input class="calc-input" id="down-payment" type="number" min="0" step="1000" placeholder="80000">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="loan-term">Loan Term</label>
            <select class="calc-select" id="loan-term">
              <option value="30">30 years</option>
              <option value="20">20 years</option>
              <option value="15">15 years</option>
              <option value="10">10 years</option>
            </select>
          </div>
          <div class="calc-field">
            <label class="calc-label" for="interest-rate">Annual Interest Rate (%)</label>
            <input class="calc-input" id="interest-rate" type="number" step="0.01" min="0" max="30" placeholder="7.0">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="prop-tax">Annual Property Tax ($/yr, optional)</label>
            <input class="calc-input" id="prop-tax" type="number" min="0" step="100" placeholder="5000">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="insurance">Annual Home Insurance ($/yr, optional)</label>
            <input class="calc-input" id="insurance" type="number" min="0" step="100" placeholder="1200">
          </div>
          <button type="submit" class="calc-btn btn-gradient text-white">Calculate Payment</button>
        </form>
        <div id="mort-result" class="calc-result hidden">
          <div class="text-center mb-md">
            <div class="text-caption text-mute mb-xxs">Monthly Payment (P+I)</div>
            <div id="monthly-pi" class="calc-result-primary"></div>
          </div>
          <div class="calc-result-row"><span class="calc-result-label">Monthly payment (with taxes & ins.)</span><span id="monthly-total" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Loan amount</span><span id="loan-amt" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Total of payments</span><span id="total-payments" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Total interest paid</span><span id="total-interest" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Down payment %</span><span id="dp-pct" class="calc-result-value"></span></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const CURR_SYMBOLS: Record<string, string> = {
    USD: '$', EUR: '€', GBP: '£', CAD: 'C$', AUD: 'A$', CHF: 'Fr.',
    JPY: '¥', CNY: '¥', INR: '₹', BRL: 'R$', MXN: 'MX$', KRW: '₩',
    SGD: 'S$', HKD: 'HK$'
  };
  const origLabels = new Map<Element, string>();
  document.querySelectorAll('.calc-label').forEach(el => {
    if (el.textContent?.includes('$')) origLabels.set(el, el.textContent!);
  });
  document.getElementById('mort-currency')!.addEventListener('change', () => {
    const sym = CURR_SYMBOLS[(document.getElementById('mort-currency') as HTMLSelectElement).value] ?? '$';
    origLabels.forEach((orig, el) => { el.textContent = orig.replace(/\$/g, sym); });
  });

  document.getElementById('mort-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const currCode = (document.getElementById('mort-currency') as HTMLSelectElement).value;
    const fmt = (v: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: currCode }).format(v);
    const price = parseFloat((document.getElementById('home-price') as HTMLInputElement).value);
    const down = parseFloat((document.getElementById('down-payment') as HTMLInputElement).value) || 0;
    const years = parseInt((document.getElementById('loan-term') as HTMLSelectElement).value);
    const rate = parseFloat((document.getElementById('interest-rate') as HTMLInputElement).value);
    const propTax = parseFloat((document.getElementById('prop-tax') as HTMLInputElement).value) || 0;
    const insurance = parseFloat((document.getElementById('insurance') as HTMLInputElement).value) || 0;

    if (!price || !rate) return;

    const principal = price - down;
    const r = rate / 100 / 12;
    const n = years * 12;
    const pi = r === 0 ? principal / n : principal * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
    const monthlyTotal = pi + propTax / 12 + insurance / 12;
    const totalPayments = pi * n;
    const totalInterest = totalPayments - principal;

    document.getElementById('monthly-pi')!.textContent = fmt(pi);
    document.getElementById('monthly-total')!.textContent = fmt(monthlyTotal);
    document.getElementById('loan-amt')!.textContent = fmt(principal);
    document.getElementById('total-payments')!.textContent = fmt(totalPayments);
    document.getElementById('total-interest')!.textContent = fmt(totalInterest);
    document.getElementById('dp-pct')!.textContent = ((down / price) * 100).toFixed(1) + '%';

    const result = document.getElementById('mort-result')!;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
