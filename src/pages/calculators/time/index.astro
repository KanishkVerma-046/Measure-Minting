---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout title="Time Calculator — Add & Subtract Time | MeasureMinting" description="Add or subtract hours, minutes, and seconds. Calculate elapsed time between two times." path="/calculators/time/">
  <div class="calc-hero px-md py-2xl sm:py-3xl sm:px-lg">
    <div class="mx-auto max-w-[1400px] text-center">
      <div class="mx-auto mb-md inline-flex items-center rounded-full bg-link-bg-soft px-sm py-xxs text-caption font-medium text-link">Other</div>
      <h1 class="text-display-lg text-ink">Time Calculator</h1>
      <p class="mx-auto mt-sm max-w-[56ch] text-body-lg text-body">Add or subtract hours, minutes, and seconds with instant results.</p>
    </div>
  </div>
  <section class="px-md py-2xl sm:px-lg pb-section">
    <div class="mx-auto max-w-[42rem] space-y-md">

      <div class="calc-card">
        <h2 class="text-display-sm text-ink mb-lg">Add / Subtract Time Values</h2>
        <div id="time-rows">
          <div class="time-row flex gap-xs items-center mb-sm">
            <select class="calc-select" style="flex:0 0 80px"><option value="1">+</option><option value="-1">−</option></select>
            <input class="calc-input text-center" type="number" min="0" placeholder="0" style="flex:1" title="Hours">
            <span class="text-mute text-body-sm">h</span>
            <input class="calc-input text-center" type="number" min="0" max="59" placeholder="0" style="flex:1" title="Minutes">
            <span class="text-mute text-body-sm">m</span>
            <input class="calc-input text-center" type="number" min="0" max="59" placeholder="0" style="flex:1" title="Seconds">
            <span class="text-mute text-body-sm">s</span>
          </div>
        </div>
        <div class="flex gap-sm mt-md">
          <button id="add-row" type="button" class="inline-flex items-center gap-xs rounded-xl border border-hairline bg-canvas px-md py-xs text-body-sm-strong hover:bg-link-bg-soft hover:border-link hover:text-link transition-colors">
            + Add row
          </button>
          <button id="calc-time" type="button" class="calc-btn btn-gradient text-white flex-1" style="margin-top:0">Calculate</button>
        </div>
        <div id="time-result" class="calc-result hidden mt-lg">
          <div class="text-center">
            <div class="text-caption text-mute mb-xxs">Total</div>
            <div id="time-total" class="calc-result-primary"></div>
          </div>
          <div class="calc-result-row"><span class="calc-result-label">Hours only</span><span id="time-h-only" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Minutes only</span><span id="time-m-only" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Seconds only</span><span id="time-s-only" class="calc-result-value"></span></div>
        </div>
      </div>

      <div class="calc-card">
        <h2 class="text-display-sm text-ink mb-lg">Elapsed Time Between Two Times</h2>
        <form id="elapsed-form">
          <div class="flex gap-sm">
            <div class="calc-field flex-1"><label class="calc-label" for="start-time">Start Time</label><input class="calc-input" id="start-time" type="time" step="1"></div>
            <div class="calc-field flex-1"><label class="calc-label" for="end-time">End Time</label><input class="calc-input" id="end-time" type="time" step="1"></div>
          </div>
          <button type="submit" class="calc-btn btn-gradient text-white">Calculate Elapsed</button>
        </form>
        <div id="elapsed-result" class="calc-result hidden">
          <div class="text-center">
            <div class="text-caption text-mute mb-xxs">Elapsed Time</div>
            <div id="elapsed-val" class="calc-result-primary"></div>
          </div>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  function secsToHMS(s: number): string {
    const sign = s < 0 ? '-' : '';
    s = Math.abs(Math.round(s));
    const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
    return `${sign}${h}h ${String(m).padStart(2,'0')}m ${String(sec).padStart(2,'0')}s`;
  }

  document.getElementById('add-row')!.addEventListener('click', () => {
    const row = document.createElement('div');
    row.className = 'time-row flex gap-xs items-center mb-sm';
    row.innerHTML = `
      <select class="calc-select" style="flex:0 0 80px"><option value="1">+</option><option value="-1">−</option></select>
      <input class="calc-input text-center" type="number" min="0" placeholder="0" style="flex:1">
      <span class="text-mute text-body-sm">h</span>
      <input class="calc-input text-center" type="number" min="0" max="59" placeholder="0" style="flex:1">
      <span class="text-mute text-body-sm">m</span>
      <input class="calc-input text-center" type="number" min="0" max="59" placeholder="0" style="flex:1">
      <span class="text-mute text-body-sm">s</span>
    `;
    document.getElementById('time-rows')!.appendChild(row);
  });

  document.getElementById('calc-time')!.addEventListener('click', () => {
    let total = 0;
    document.querySelectorAll('.time-row').forEach(row => {
      const sign = parseInt((row.querySelector('select') as HTMLSelectElement).value);
      const inputs = row.querySelectorAll('input[type="number"]');
      const h = parseFloat((inputs[0] as HTMLInputElement).value) || 0;
      const m = parseFloat((inputs[1] as HTMLInputElement).value) || 0;
      const s = parseFloat((inputs[2] as HTMLInputElement).value) || 0;
      total += sign * (h * 3600 + m * 60 + s);
    });

    const absTotal = Math.abs(Math.round(total));
    document.getElementById('time-total')!.textContent = secsToHMS(total);
    document.getElementById('time-h-only')!.textContent = (total / 3600).toFixed(4) + ' hours';
    document.getElementById('time-m-only')!.textContent = (total / 60).toFixed(2) + ' minutes';
    document.getElementById('time-s-only')!.textContent = Math.round(total).toLocaleString() + ' seconds';

    const result = document.getElementById('time-result')!;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  document.getElementById('elapsed-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const start = (document.getElementById('start-time') as HTMLInputElement).value;
    const end = (document.getElementById('end-time') as HTMLInputElement).value;
    if (!start || !end) return;

    const toSecs = (t: string) => { const [h,m,s='0'] = t.split(':'); return parseInt(h)*3600+parseInt(m)*60+parseInt(s); };
    let diff = toSecs(end) - toSecs(start);
    if (diff < 0) diff += 86400; // next day

    document.getElementById('elapsed-val')!.textContent = secsToHMS(diff);
    const result = document.getElementById('elapsed-result')!;
    result.classList.remove('hidden');
  });
</script>
