---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout title="BMI Calculator — Free Online Tool | MeasureMinting" description="Calculate your Body Mass Index (BMI) from height and weight. Includes weight category and healthy weight range." path="/calculators/bmi/">
  <div class="calc-hero px-md py-2xl sm:py-3xl sm:px-lg">
    <div class="mx-auto max-w-[1400px] text-center">
      <div class="mx-auto mb-md inline-flex items-center rounded-full bg-link-bg-soft px-sm py-xxs text-caption font-medium text-link">Health & Fitness</div>
      <h1 class="text-display-lg text-ink">BMI Calculator</h1>
      <p class="mx-auto mt-sm max-w-[56ch] text-body-lg text-body">Calculate your Body Mass Index to determine your weight category.</p>
    </div>
  </div>
  <section class="px-md py-2xl sm:px-lg pb-section">
    <div class="mx-auto max-w-[42rem]">
      <div class="calc-card">
        <form id="bmi-form">
          <div class="mb-md flex gap-sm">
            <label class="flex items-center gap-xs text-body-sm cursor-pointer"><input type="radio" name="system" value="metric" checked class="accent-link"> Metric</label>
            <label class="flex items-center gap-xs text-body-sm cursor-pointer"><input type="radio" name="system" value="imperial" class="accent-link"> Imperial (US)</label>
          </div>
          <div id="metric-fields">
            <div class="calc-field">
              <label class="calc-label" for="weight-kg">Weight (kg)</label>
              <input class="calc-input" id="weight-kg" type="number" min="1" max="500" step="0.1" placeholder="70">
            </div>
            <div class="calc-field">
              <label class="calc-label" for="height-cm">Height (cm)</label>
              <input class="calc-input" id="height-cm" type="number" min="50" max="300" step="0.1" placeholder="175">
            </div>
          </div>
          <div id="imperial-fields" class="hidden">
            <div class="calc-field">
              <label class="calc-label" for="weight-lb">Weight (lbs)</label>
              <input class="calc-input" id="weight-lb" type="number" min="1" max="1000" step="0.1" placeholder="154">
            </div>
            <div class="flex gap-sm">
              <div class="calc-field flex-1">
                <label class="calc-label" for="height-ft">Height (ft)</label>
                <input class="calc-input" id="height-ft" type="number" min="1" max="9" placeholder="5">
              </div>
              <div class="calc-field flex-1">
                <label class="calc-label" for="height-in">Height (in)</label>
                <input class="calc-input" id="height-in" type="number" min="0" max="11" step="0.1" placeholder="9">
              </div>
            </div>
          </div>
          <button type="submit" class="calc-btn btn-gradient text-white">Calculate BMI</button>
        </form>
        <div id="bmi-result" class="calc-result hidden">
          <div class="text-center mb-md">
            <div class="text-caption text-mute mb-xxs">Your BMI</div>
            <div id="bmi-value" class="calc-result-primary"></div>
            <div id="bmi-category" class="mt-xs text-body-md-strong"></div>
          </div>
          <div class="calc-result-row"><span class="calc-result-label">Healthy weight range</span><span id="healthy-range" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Status</span><span id="bmi-status" class="calc-result-value"></span></div>
        </div>
        <div class="mt-lg rounded-xl bg-canvas-soft-2 p-md text-body-sm text-body">
          <strong class="text-ink">Formula:</strong> BMI = weight(kg) ÷ height(m)²
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('bmi-form') as HTMLFormElement;
  const result = document.getElementById('bmi-result')!;
  const bmiValue = document.getElementById('bmi-value')!;
  const bmiCategory = document.getElementById('bmi-category')!;
  const healthyRange = document.getElementById('healthy-range')!;
  const bmiStatus = document.getElementById('bmi-status')!;
  const metricFields = document.getElementById('metric-fields')!;
  const imperialFields = document.getElementById('imperial-fields')!;

  document.querySelectorAll('input[name="system"]').forEach(r => {
    r.addEventListener('change', (e) => {
      const isMetric = (e.target as HTMLInputElement).value === 'metric';
      metricFields.classList.toggle('hidden', !isMetric);
      imperialFields.classList.toggle('hidden', isMetric);
    });
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const isMetric = (document.querySelector('input[name="system"]:checked') as HTMLInputElement).value === 'metric';
    let weightKg: number, heightM: number;

    if (isMetric) {
      weightKg = parseFloat((document.getElementById('weight-kg') as HTMLInputElement).value);
      heightM = parseFloat((document.getElementById('height-cm') as HTMLInputElement).value) / 100;
    } else {
      const lb = parseFloat((document.getElementById('weight-lb') as HTMLInputElement).value);
      const ft = parseFloat((document.getElementById('height-ft') as HTMLInputElement).value) || 0;
      const inch = parseFloat((document.getElementById('height-in') as HTMLInputElement).value) || 0;
      weightKg = lb * 0.453592;
      heightM = (ft * 12 + inch) * 0.0254;
    }

    if (!weightKg || !heightM || heightM <= 0) return;

    const bmi = weightKg / (heightM * heightM);
    bmiValue.textContent = bmi.toFixed(1);

    let category = '', color = '';
    if (bmi < 18.5) { category = 'Underweight'; color = '#0891b2'; }
    else if (bmi < 25) { category = 'Normal weight'; color = '#059669'; }
    else if (bmi < 30) { category = 'Overweight'; color = '#d97706'; }
    else { category = 'Obese'; color = '#dc2626'; }

    bmiCategory.textContent = category;
    bmiCategory.style.color = color;
    bmiStatus.textContent = category;
    bmiStatus.style.color = color;

    const minKg = 18.5 * heightM * heightM;
    const maxKg = 24.9 * heightM * heightM;
    if (isMetric) {
      healthyRange.textContent = `${minKg.toFixed(1)} – ${maxKg.toFixed(1)} kg`;
    } else {
      healthyRange.textContent = `${(minKg * 2.20462).toFixed(1)} – ${(maxKg * 2.20462).toFixed(1)} lbs`;
    }

    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
