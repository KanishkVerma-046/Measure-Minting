---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout title="Payment Calculator — Solve for Payment, Rate, or Term | MeasureMinting" description="Solve for any unknown loan variable: monthly payment, interest rate, loan term, or principal." path="/calculators/payment/">
  <div class="calc-hero px-md py-2xl sm:py-3xl sm:px-lg">
    <div class="mx-auto max-w-[1400px] text-center">
      <div class="mx-auto mb-md inline-flex items-center rounded-full bg-link-bg-soft px-sm py-xxs text-caption font-medium text-link">Financial</div>
      <h1 class="text-display-lg text-ink">Payment Calculator</h1>
      <p class="mx-auto mt-sm max-w-[56ch] text-body-lg text-body">Solve for any loan variable — enter three values to find the fourth.</p>
    </div>
  </div>
  <section class="px-md py-2xl sm:px-lg pb-section">
    <div class="mx-auto max-w-[42rem]">
      <div class="calc-card">
        <p class="text-body-sm text-body mb-md">Leave one field blank to solve for it.</p>
        <form id="pay-form">
          <div class="calc-field">
            <label class="calc-label" for="pay-principal">Loan Amount ($)</label>
            <input class="calc-input" id="pay-principal" type="number" min="0" step="500" placeholder="Leave blank to solve">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="pay-rate">Annual Interest Rate (%)</label>
            <input class="calc-input" id="pay-rate" type="number" step="0.01" min="0" placeholder="Leave blank to solve">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="pay-months">Loan Term (months)</label>
            <input class="calc-input" id="pay-months" type="number" min="1" placeholder="Leave blank to solve">
          </div>
          <div class="calc-field">
            <label class="calc-label" for="pay-payment">Monthly Payment ($)</label>
            <input class="calc-input" id="pay-payment" type="number" step="0.01" min="0" placeholder="Leave blank to solve">
          </div>
          <button type="submit" class="calc-btn btn-gradient text-white">Solve</button>
        </form>
        <div id="pay-result" class="calc-result hidden">
          <div class="calc-result-row"><span class="calc-result-label">Loan amount</span><span id="pay-r-p" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Annual rate</span><span id="pay-r-rate" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Term</span><span id="pay-r-term" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Monthly payment</span><span id="pay-r-pmt" class="calc-result-primary" style="font-size:1.4rem"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Total interest</span><span id="pay-r-int" class="calc-result-value"></span></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.getElementById('pay-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const pVal = (document.getElementById('pay-principal') as HTMLInputElement).value;
    const rVal = (document.getElementById('pay-rate') as HTMLInputElement).value;
    const nVal = (document.getElementById('pay-months') as HTMLInputElement).value;
    const pmtVal = (document.getElementById('pay-payment') as HTMLInputElement).value;

    const P = pVal ? parseFloat(pVal) : null;
    const rAnn = rVal ? parseFloat(rVal) / 100 : null;
    const n = nVal ? parseInt(nVal) : null;
    const PMT = pmtVal ? parseFloat(pmtVal) : null;

    const blanks = [P, rAnn, n, PMT].filter(v => v === null).length;
    if (blanks !== 1) { alert('Please leave exactly one field blank.'); return; }

    let resP = P!, resR = rAnn!, resN = n!, resPMT = PMT!;
    const fmt$ = (v: number) => '$' + v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    if (PMT === null) {
      const r = resR / 12;
      resPMT = r === 0 ? resP / resN : resP * (r * Math.pow(1+r,resN)) / (Math.pow(1+r,resN)-1);
    } else if (P === null) {
      const r = resR / 12;
      resP = r === 0 ? resPMT * resN : resPMT * (Math.pow(1+r,resN)-1) / (r * Math.pow(1+r,resN));
    } else if (n === null) {
      const r = resR / 12;
      resN = r === 0 ? resP / resPMT : Math.round(-Math.log(1 - resP*r/resPMT) / Math.log(1+r));
    } else if (rAnn === null) {
      // Newton's method for rate
      let r = 0.005;
      for (let i = 0; i < 100; i++) {
        const f = resP * (r * Math.pow(1+r,resN)) / (Math.pow(1+r,resN)-1) - resPMT;
        const df = resP * (Math.pow(1+r,resN)*(1+r*resN) - 1) / Math.pow(Math.pow(1+r,resN)-1, 2);
        r -= f/df;
        if (Math.abs(f) < 0.0001) break;
      }
      resR = r * 12;
    }

    document.getElementById('pay-r-p')!.textContent = fmt$(resP);
    document.getElementById('pay-r-rate')!.textContent = (resR * 100).toFixed(2) + '%';
    document.getElementById('pay-r-term')!.textContent = resN + ' months (' + (resN/12).toFixed(1) + ' yrs)';
    document.getElementById('pay-r-pmt')!.textContent = fmt$(resPMT);
    document.getElementById('pay-r-int')!.textContent = fmt$(resPMT * resN - resP);

    const result = document.getElementById('pay-result')!;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
