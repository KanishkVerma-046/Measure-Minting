---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout title="Inflation Calculator — Purchasing Power Over Time | MeasureMinting" description="Calculate the impact of inflation on purchasing power. Find the equivalent value of money across different years." path="/calculators/inflation/">
  <div class="calc-hero px-md py-2xl sm:py-3xl sm:px-lg">
    <div class="mx-auto max-w-[1400px] text-center">
      <div class="mx-auto mb-md inline-flex items-center rounded-full bg-link-bg-soft px-sm py-xxs text-caption font-medium text-link">Financial</div>
      <h1 class="text-display-lg text-ink">Inflation Calculator</h1>
      <p class="mx-auto mt-sm max-w-[56ch] text-body-lg text-body">Calculate how inflation erodes purchasing power over time.</p>
    </div>
  </div>
  <section class="px-md py-2xl sm:px-lg pb-section">
    <div class="mx-auto max-w-[42rem]">
      <div class="calc-card">
        <form id="inf-form">
          <div class="calc-field">
            <label class="calc-label" for="inf-currency">Currency</label>
            <select class="calc-select" id="inf-currency">
              <option value="USD">USD – US Dollar ($)</option>
              <option value="EUR">EUR – Euro (€)</option>
              <option value="GBP">GBP – British Pound (£)</option>
              <option value="CAD">CAD – Canadian Dollar (C$)</option>
              <option value="AUD">AUD – Australian Dollar (A$)</option>
              <option value="CHF">CHF – Swiss Franc (Fr.)</option>
              <option value="JPY">JPY – Japanese Yen (¥)</option>
              <option value="CNY">CNY – Chinese Yuan (¥)</option>
              <option value="INR">INR – Indian Rupee (₹)</option>
              <option value="BRL">BRL – Brazilian Real (R$)</option>
              <option value="MXN">MXN – Mexican Peso (MX$)</option>
              <option value="KRW">KRW – South Korean Won (₩)</option>
              <option value="SGD">SGD – Singapore Dollar (S$)</option>
              <option value="HKD">HKD – Hong Kong Dollar (HK$)</option>
            </select>
          </div>
          <div class="calc-field">
            <label class="calc-label" for="inf-amount">Amount ($)</label>
            <input class="calc-input" id="inf-amount" type="number" min="0" step="100" placeholder="1000">
          </div>
          <div class="flex gap-sm">
            <div class="calc-field flex-1">
              <label class="calc-label" for="inf-from-year">From Year</label>
              <input class="calc-input" id="inf-from-year" type="number" min="1900" max="2100" placeholder="2000">
            </div>
            <div class="calc-field flex-1">
              <label class="calc-label" for="inf-to-year">To Year</label>
              <input class="calc-input" id="inf-to-year" type="number" min="1900" max="2100" placeholder="2024">
            </div>
          </div>
          <div class="calc-field">
            <label class="calc-label" for="inf-rate">Annual Inflation Rate (%)</label>
            <input class="calc-input" id="inf-rate" type="number" step="0.1" min="0" placeholder="3.5">
          </div>
          <button type="submit" class="calc-btn btn-gradient text-white">Calculate</button>
        </form>
        <div id="inf-result" class="calc-result hidden">
          <div class="text-center mb-md">
            <div class="text-caption text-mute mb-xxs">Equivalent Value</div>
            <div id="inf-value" class="calc-result-primary"></div>
          </div>
          <div class="calc-result-row"><span class="calc-result-label">Original amount</span><span id="inf-original" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Years elapsed</span><span id="inf-years" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Cumulative inflation</span><span id="inf-cumulative" class="calc-result-value"></span></div>
          <div class="calc-result-row"><span class="calc-result-label">Purchasing power change</span><span id="inf-change" class="calc-result-value"></span></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const CURR_SYMBOLS: Record<string, string> = {
    USD: '$', EUR: '€', GBP: '£', CAD: 'C$', AUD: 'A$', CHF: 'Fr.',
    JPY: '¥', CNY: '¥', INR: '₹', BRL: 'R$', MXN: 'MX$', KRW: '₩',
    SGD: 'S$', HKD: 'HK$'
  };
  const origLabels = new Map<Element, string>();
  document.querySelectorAll('.calc-label').forEach(el => {
    if (el.textContent?.includes('$')) origLabels.set(el, el.textContent!);
  });
  document.getElementById('inf-currency')!.addEventListener('change', () => {
    const sym = CURR_SYMBOLS[(document.getElementById('inf-currency') as HTMLSelectElement).value] ?? '$';
    origLabels.forEach((orig, el) => { el.textContent = orig.replace(/\$/g, sym); });
  });

  document.getElementById('inf-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const currCode = (document.getElementById('inf-currency') as HTMLSelectElement).value;
    const fmt = (v: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: currCode }).format(v);
    const amount = parseFloat((document.getElementById('inf-amount') as HTMLInputElement).value);
    const fromYear = parseInt((document.getElementById('inf-from-year') as HTMLInputElement).value);
    const toYear = parseInt((document.getElementById('inf-to-year') as HTMLInputElement).value);
    const rate = parseFloat((document.getElementById('inf-rate') as HTMLInputElement).value);

    if (!amount || !fromYear || !toYear || isNaN(rate)) return;

    const years = toYear - fromYear;
    const multiplier = Math.pow(1 + rate / 100, years);
    const equivalent = amount * multiplier;
    const cumulative = (multiplier - 1) * 100;
    const powerChange = (1 / multiplier - 1) * 100;

    document.getElementById('inf-value')!.textContent = fmt(equivalent);
    document.getElementById('inf-original')!.textContent = fmt(amount);
    document.getElementById('inf-years')!.textContent = Math.abs(years) + ' years';
    document.getElementById('inf-cumulative')!.textContent = cumulative.toFixed(1) + '%';
    document.getElementById('inf-change')!.textContent = powerChange.toFixed(1) + '%';

    const result = document.getElementById('inf-result')!;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
